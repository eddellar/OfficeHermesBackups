{
  "_comment": "Wan 2.2 text-to-video. Local models: E:/ComfyUI_windows_portable/ComfyUI/models/. Text encoder: umt5-xxl-enc-fp8_e4m3fn.safetensors in text_encoders/. Diffusion models in diffusion_models/Wan2.2/T2V/. VAE: wan2.2_t2v_vae.safetensors in vae/Wan_2.2/ (16ch T2V VAE, NOT 48ch I2V). Output: MP4 via CreateVideo+SaveVideo.",
  "5": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": {"title": "Wan Text Encoder"},
    "inputs": {
      "model_name": "Wan\\umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "device": "auto",
      "compile": false
    }
  },
  "6": {
    "class_type": "WanVideoTextEncode",
    "_meta": {"title": "Positive Prompt"},
    "inputs": {
      "positive_prompt": "a graceful crane taking flight from a misty lake at dawn, slow motion, 4k, cinematic",
      "negative_prompt": "static, blurry, watermark, low quality, distorted",
      "t5": ["5", 0],
      "force_offload": true,
      "device": "gpu"
    }
  },
  "7": {
    "class_type": "WanVideoEmptyEmbeds",
    "_meta": {"title": "Latent Video"},
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 25,
      "batch_size": 1
    }
  },
  "3": {
    "class_type": "WanVideoModelLoader",
    "_meta": {"title": "Wan Model"},
    "inputs": {
      "model": "Wan2.2\\T2V\\wan2.2_t2v_high_noise_14B_fp16.safetensors",
      "base_precision": "fp16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "load_device_switch": "offload_device"
    }
  },
  "4": {
    "class_type": "WanVideoSampler",
    "_meta": {"title": "Wan Sampler"},
    "inputs": {
      "model": ["3", 0],
      "image_embeds": ["7", 0],
      "text_embeds": ["6", 0],
      "steps": 30,
      "cfg": 1.0,
      "shift": 5.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0
    }
  },
  "8": {
    "class_type": "WanVideoVAELoader",
    "_meta": {"title": "Wan VAE (T2V 16ch)"},
    "inputs": {
      "model_name": "Wan_2.2\\wan2.2_t2v_vae.safetensors",
      "precision": "fp16"
    }
  },
  "10": {
    "class_type": "WanVideoDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "vae": ["8", 0],
      "samples": ["4", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 16,
      "tile_stride_y": 16,
      "denoise": 1.0
    }
  },
  "11": {
    "class_type": "CreateVideo",
    "_meta": {"title": "Create Video"},
    "inputs": {
      "images": ["10", 0],
      "fps": 24.0
    }
  },
  "12": {
    "class_type": "SaveVideo",
    "_meta": {"title": "Save Video"},
    "inputs": {
      "video": ["11", 0],
      "filename_prefix": "wan_t2v",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
